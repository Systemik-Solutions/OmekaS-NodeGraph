<script>
    (function($) {
        function wire(scope) {
            // For each Node Icons collection fieldset
            $(scope).find('fieldset.node_graph_node_icons').each(function() {
                const $coll = $(this); // rows collection (fieldset)
                const $block = $coll.closest('.block'); // scope to same block
                const $group = $block.find('select.node_graph_group_by_select').first();
                if (!$group.length) return;

                // Helpers — locate the 3 possible target selectors in a row
                function getTargets($row) {
                    const $rc = $row.find('.ngi--rc'); // resource class select
                    const $rt = $row.find('.ngi--rt'); // resource template select
                    const $pv = $row.find('.ngi--pv'); // property select (optional)
                    return {
                        rcSel: $rc,
                        rcField: $rc.closest('.field'),
                        rtSel: $rt,
                        rtField: $rt.closest('.field'),
                        pvSel: $pv,
                        pvField: $pv.closest('.field'),
                    };
                }

                function clearAndHide($sel, $field) {
                    if (!$sel.length || !$field.length) return;
                    if ($sel.is('select')) {
                        // if chosen, destroy first
                        if ($.fn.chosen && $sel.data('chosen')) {
                            try {
                                $sel.chosen('destroy');
                            } catch (e) {}
                        }
                        $sel.val('').trigger('change');
                    } else {
                        $sel.val('');
                    }
                    $field.hide();
                }

                function showField($sel, $field) {
                    if (!$sel.length || !$field.length) return;
                    $field.show();
                    // init chosen only for property select if present
                    if ($sel.hasClass('ngi--pv') && $.fn.chosen && !$sel.data('chosen')) {
                        $sel.chosen({
                            include_group_label_in_selected: true,
                            width: '100%'
                        });
                    }
                }

                function showForType($row, type) {
                    const t = getTargets($row);
                    if (type === 'resource_class') {
                        clearAndHide(t.rtSel, t.rtField);
                        clearAndHide(t.pvSel, t.pvField);
                        showField(t.rcSel, t.rcField);
                    } else if (type === 'resource_template') {
                        clearAndHide(t.rcSel, t.rcField);
                        clearAndHide(t.pvSel, t.pvField);
                        showField(t.rtSel, t.rtField);
                    } else if (type === 'property_value') {
                        clearAndHide(t.rcSel, t.rcField);
                        clearAndHide(t.rtSel, t.rtField);
                        showField(t.pvSel, t.pvField);
                    }
                }

                // Icon picker per row: select.ngi-icon-select + input.ngi-icon-custom
                function wireIconRow($row) {
                    const $iconSel = $row.find('.ngi-icon-select'); // your FA list + "custom"
                    const $iconCustom = $row.find('.ngi-icon-custom'); // free text for FA class

                    function updateIconInputs() {
                        if (!$iconSel.length || !$iconCustom.length) return;
                        if ($iconSel.val() === 'custom') {
                            $iconCustom.show().attr('required', true);
                        } else {
                            $iconCustom.val('').hide().removeAttr('required');
                        }
                    }
                    updateIconInputs();
                    $iconSel.off('.ngiIcon').on('change.ngiIcon', updateIconInputs);
                }

                function applyAll() {
                    const type = $group.val(); // 'resource_class' | 'resource_template' | 'property_value'
                    $coll.children('fieldset').each(function() {
                        const $row = $(this);
                        showForType($row, type);
                        wireIconRow($row);
                    });
                }

                // Initial state + react to Group By changes
                applyAll();
                $group.off('.ngiGroup').on('change.ngiGroup', applyAll);


                //  remove handler
                $coll.off('click.ngiRemove').on('click.ngiRemove', '.ngi-remove', function(e) {
                    e.preventDefault();
                    const $row = $(this).closest('fieldset'); 
                    // clean up any chosen selects in that row
                    $row.find('select.chosen-select').each(function() {
                        if ($.fn.chosen && $(this).data('chosen')) {
                            try {
                                $(this).chosen('destroy');
                            } catch (e) {}
                            $(this).removeData('chosen');
                        }
                    });
                    $row.remove();
                });

                // Template & +Add button
                const $tmplHolder = $coll.find('[data-template]').first();
                if ($tmplHolder.length && !$coll.data('ngi-add-bound')) {
                    $coll.data('ngi-add-bound', 1);

                    const $layout = $block.find('input[name^="o:block["][name$="[o:layout]"]').first();
                    const m = $layout.length ? $layout.attr('name').match(/^o:block\[(\d+)\]\[o:layout\]$/) : null;
                    const blockIdx = m ? m[1] : null;

                    const rawTemplate = $tmplHolder.attr('data-template') || '';
                    const bakedTemplate = blockIdx != null ?
                        rawTemplate.replace(/__blockIndex__/g, String(blockIdx)) :
                        rawTemplate;

                    const $add = $('<button type="button" class="button ngi-add" style="margin-top:.5rem;">+ Add icon</button>');
                    $coll.after($add);

                    $add.on('click', function() {
                        const idx = $coll.children('fieldset').length;
                        const html = bakedTemplate.replace(/__index__/g, String(idx));
                        const $row = $(html);
                        $coll.append($row);

                        // wire behaviors for the new row
                        showForType($row, $group.val());
                        wireIconRow($row);

                        // remove row button (expects .ngi-remove inside the row)
                        $row.on('click', '.ngi-remove', function() {
                            $row.remove();
                        });
                    });
                }
            });
        }

        // Boot + rewire when admin dynamically adds blocks
        $(function() {
            wire(document);
        });
        $(document).on('o:block-added o:form-loaded', function(e, ctx) {
            wire(ctx || document);
        });
    })(jQuery);
</script>